# Router
COMMERCE_AGENT_ROUTER_PROVIDER=auto
COMMERCE_AGENT_ROUTER_MODEL=glm-4-flash

# BigModel embeddings and router
BIGMODEL_API_KEY=
BIGMODEL_BASE_URL=https://open.bigmodel.cn/api/paas/v4
COMMERCE_AGENT_EMBEDDING_PROVIDER=deterministic
BIGMODEL_EMBEDDING_MODEL=embedding-3
BIGMODEL_EMBEDDING_DIMENSIONS=1024

# Vision
OPENAI_API_KEY=
COMMERCE_AGENT_VISION_MODEL=gpt-4.1-mini
COMMERCE_AGENT_MOCK_VISION=1
COMMERCE_AGENT_MOCK_VISION_RESPONSE=

# Database
DATABASE_URL=postgresql://commerce_agent:commerce_agent@127.0.0.1:5432/commerce_agent

# Web
COMMERCE_AGENT_HOST=127.0.0.1
COMMERCE_AGENT_PORT=8000
